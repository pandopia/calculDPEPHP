#!/usr/bin/env php
<?php

declare(strict_types=1);

use CalculDpe\XmlSanitizer;

require __DIR__ . '/../vendor/autoload.php';

// ── Usage ──────────────────────────────────────────────────────────────────
if ($argc < 2) {
    fwrite(STDERR, "Usage: php bin/fetch-dpe <NUMERO_ADEME> [--dry-run]\n");
    fwrite(STDERR, "  Exemple : php bin/fetch-dpe 2517E0227225G\n");
    fwrite(STDERR, "  Stocke le XML ADEME dans resources/XML/verif/ et resources/XML/input/\n");
    exit(1);
}

$numAdeme  = strtoupper(trim($argv[1]));
$dryRun    = in_array('--dry-run', $argv, true);

// ── Credentials MuleSoft ADEME (observatoire-dpe-audit.ademe.fr) ──────────
$accounts = [
    ['clientId' => '067d763742714d5fb9840e60c5aec6d1', 'clientSecret' => '8791eDB68B0f4D76b654885b44949e62'],
    ['clientId' => '16d119b9103c498ebcdb690b0e91099f', 'clientSecret' => '8ed9E321ae6240299300e695fB55af99'],
];

// ── Helpers ────────────────────────────────────────────────────────────────
function correctNumAdeme(string $n): string
{
    // Corrections OCR connues (dernière lettre)
    $last = substr($n, -1);
    if ($last === '1') return substr_replace($n, 'I', -1);
    if ($last === '0') return substr_replace($n, 'O', -1);
    if ($last === '5') return substr_replace($n, 'S', -1);
    return $n;
}

function isNumAdemeValid(string $n): bool
{
    return (bool) preg_match('/^\d{4}[A-Z]{1}\d{7}[A-Z]{1}$/', $n);
}

function fetchXml(string $numAdeme, array $accounts): string
{
    $apiBase = 'https://prd-x-ademe-externe-api.de-c1.eu1.cloudhub.io/api/v1/pub/';
    $url     = $apiBase . 'dpe/' . $numAdeme . '/xml';

    $account = $accounts[array_rand($accounts)];

    for ($attempt = 1; $attempt <= 3; $attempt++) {
        $curl = curl_init();
        curl_setopt_array($curl, [
            CURLOPT_URL            => $url,
            CURLOPT_HEADER         => true,
            CURLOPT_RETURNTRANSFER => true,
            CURLOPT_TIMEOUT        => 30,
            CURLOPT_HTTPHEADER     => [
                'client_id: '     . $account['clientId'],
                'client_secret: ' . $account['clientSecret'],
            ],
        ]);

        $raw        = curl_exec($curl);
        $headerSize = curl_getinfo($curl, CURLINFO_HEADER_SIZE);
        $httpCode   = curl_getinfo($curl, CURLINFO_HTTP_CODE);
        $body       = substr($raw, $headerSize);
        curl_close($curl);

        if ($httpCode === 404) {
            throw new RuntimeException("DPE $numAdeme introuvable sur l'observatoire (404).");
        }
        if ($httpCode >= 500) {
            fwrite(STDERR, "Tentative $attempt/3 — HTTP $httpCode, retry...\n");
            sleep(2);
            continue;
        }
        if (empty($body)) {
            fwrite(STDERR, "Tentative $attempt/3 — réponse vide, retry...\n");
            sleep(2);
            continue;
        }
        if (!str_contains($body, 'date_etablissement_dpe')) {
            // L'API renvoie du JSON quand le DPE n'existe pas
            $json = json_decode($body, true);
            $msg  = $json['message'] ?? $json['error'] ?? substr($body, 0, 120);
            throw new RuntimeException("Réponse inattendue pour $numAdeme : $msg");
        }

        return $body;
    }

    throw new RuntimeException("Aucune réponse valide après 3 tentatives pour $numAdeme.");
}

// ── Correction et validation ───────────────────────────────────────────────
$numAdeme = correctNumAdeme($numAdeme);

if (!isNumAdemeValid($numAdeme)) {
    fwrite(STDERR, "Numéro ADEME invalide après correction : $numAdeme\n");
    fwrite(STDERR, "Format attendu : 4 chiffres + 1 lettre + 7 chiffres + 1 lettre (ex: 2517E0227225G)\n");
    exit(1);
}

fwrite(STDOUT, "Numéro ADEME : $numAdeme\n");

// ── Fallback sur variante de dernière lettre ───────────────────────────────
$xmlContent = null;
$candidates = [$numAdeme];

// Variantes connues si l'API renvoie 404 (OCR : O↔Q, F↔E)
$last = substr($numAdeme, -1);
if ($last === 'O') {
    $candidates[] = substr_replace($numAdeme, 'Q', -1);
} elseif ($last === 'F') {
    $candidates[] = substr_replace($numAdeme, 'E', -1);
} elseif (str_starts_with($numAdeme, '2433F')) {
    $candidates[] = '2433E' . substr($numAdeme, 5);
}

foreach ($candidates as $candidate) {
    try {
        fwrite(STDOUT, "Récupération XML sur l'observatoire ADEME ($candidate)...\n");
        $xmlContent  = fetchXml($candidate, $accounts);
        $numAdeme    = $candidate; // on garde le numéro qui a fonctionné
        break;
    } catch (RuntimeException $e) {
        fwrite(STDERR, "  ✗ $candidate : " . $e->getMessage() . "\n");
    }
}

if ($xmlContent === null) {
    fwrite(STDERR, "Échec : impossible de récupérer le DPE.\n");
    exit(1);
}

fwrite(STDOUT, sprintf("XML récupéré (%d octets).\n", strlen($xmlContent)));

// ── Dry-run : affiche seulement ───────────────────────────────────────────
if ($dryRun) {
    fwrite(STDOUT, "Mode dry-run : aucun fichier écrit.\n");
    fwrite(STDOUT, substr($xmlContent, 0, 500) . "\n...\n");
    exit(0);
}

// ── Écriture temporaire → XmlSanitizer ────────────────────────────────────
$projectRoot   = dirname(__DIR__);
$verifDir      = $projectRoot . '/resources/XML/verif';
$inputDir      = $projectRoot . '/resources/XML/input';
$tmpFile       = sys_get_temp_dir() . '/' . $numAdeme . '.xml';

file_put_contents($tmpFile, $xmlContent);

try {
    $sanitizer = new XmlSanitizer();
    $result    = $sanitizer->process($tmpFile, $verifDir, $inputDir);

    fwrite(STDOUT, "\n✓ Fichiers créés :\n");
    fwrite(STDOUT, "  Verif (avec données) : " . $result['verif']  . "\n");
    fwrite(STDOUT, "  Input (sans données) : " . $result['input']  . "\n");
    fwrite(STDOUT, "  Balises supprimées   : " . $result['removed_count'] . "\n");
} finally {
    @unlink($tmpFile);
}

fwrite(STDOUT, "\nPour lancer le calcul :\n");
fwrite(STDOUT, "  php bin/calcul-dpe " . $result['input'] . "\n");
