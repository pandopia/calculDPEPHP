// ── Helpers XML ────────────────────────────────────────────────────────────
function readXmlLeaves(string $path): array
{
    $doc = new DOMDocument();
    $doc->preserveWhiteSpace = false;
    $doc->load($path);
    $out = [];
    foreach (['donnee_intermediaire', 'sortie'] as $container) {
        foreach ($doc->getElementsByTagName($container) as $node) {
            if ($node instanceof DOMElement) {
                collectLeaves($node, pathOf($node), $out);
            }
        }
    }
    return $out;
}

function pathOf(DOMElement $node): string
{
    $parts = []; $cursor = $node;
    while ($cursor instanceof DOMElement) {
        $parts[] = $cursor->nodeName;
        $cursor  = $cursor->parentNode instanceof DOMElement ? $cursor->parentNode : null;
    }
    return implode('/', array_reverse($parts));
}

function collectLeaves(DOMElement $node, string $path, array &$out): void
{
    $hasEl = false;
    foreach ($node->childNodes as $child) {
        if ($child instanceof DOMElement) { $hasEl = true; collectLeaves($child, $path . '/' . $child->nodeName, $out); }
    }
    if (!$hasEl) $out[$path] = trim($node->textContent ?? '');
}

function filterByTag(array $values, array $tagSet): array
{
    $out = [];
    foreach ($values as $path => $v) {
        $leaf = (string)substr((string)strrchr('/' . $path, '/'), 1);
        if (isset($tagSet[$leaf])) $out[$path] = $v;
    }
    return $out;
}

/**
 * Détecte les DPE « logement_neuf » (RE2020 / RT2012) — racine
 * `<dpe>/<logement_neuf>` au lieu de `<dpe>/<logement>` — qui suivent une
 * méthodologie différente du 3CL-2021 et ne sont pas couverts par ce moteur.
 */
function isDpeNeuf(string $path): bool
{
    $r = new XMLReader();
    if (!$r->open($path)) return false;
    $isNeuf = false;
    while ($r->read()) {
        if ($r->nodeType !== XMLReader::ELEMENT) continue;
        if ($r->name === 'logement_neuf') { $isNeuf = true; break; }
        if ($r->name === 'logement')       { break; }
    }
    $r->close();
    return $isNeuf;
}

function diffValues(array $expected, array $actual, array $tol): array
{
    $defaultTol = (float)$tol['default'];
    $overrides  = $tol['overrides'];
    $diffs = [];
    foreach (array_unique(array_merge(array_keys($expected), array_keys($actual))) as $key) {
        $e = $expected[$key] ?? ''; $a = $actual[$key] ?? '';
        if ($e === $a) continue;
        $tag    = (string)substr((string)strrchr('/' . $key, '/'), 1);
        $tagTol = $overrides[$tag] ?? $defaultTol;
        if (is_numeric($e) && is_numeric($a)) {
            $delta    = abs((float)$e - (float)$a);
            $relative = ((float)$e !== 0.0) ? $delta / abs((float)$e) : $delta;
            if ($relative <= $tagTol) continue;
            $diffs[] = ['path' => $key, 'expected' => $e, 'actual' => $a,
                        'delta_abs' => $delta, 'delta_rel' => $relative, 'tag' => $tag];
        } else {
            $diffs[] = ['path' => $key, 'expected' => $e, 'actual' => $a,
                        'delta_abs' => null, 'delta_rel' => null, 'tag' => $tag];
        }
    }
    return $diffs;
}

// ── Collecte des paires input/verif ───────────────────────────────────────
$pairs   = [];
$skipped = [];
foreach (glob($inputDir . '/*.xml') as $inputPath) {
    $name = basename($inputPath, '.xml');
    if (str_ends_with($name, '.calculated')) continue;
    if ($filterNum !== null && !str_contains($name, $filterNum)) continue;
    $verifPath = $verifDir . '/' . $name . '.xml';
    if (!is_file($verifPath)) continue;
    // DPE logement_neuf (RE2020 / RT2012) : méthodologie distincte du 3CL — non couvert.
    if (isDpeNeuf($inputPath)) {
        $skipped[] = $name;
        continue;
    }
    $pairs[$name] = ['input' => $inputPath, 'verif' => $verifPath];
}
foreach ($skipped as $name) {
    fwrite(STDERR, "  $name ... SKIP (DPE neuf)\n");
}
ksort($pairs);

if (empty($pairs)) {
    fwrite(STDERR, "Aucune paire input/verif trouvée" . ($filterNum ? " pour '$filterNum'" : "") . ".\n");
    exit(1);
}

// ── Lancement ─────────────────────────────────────────────────────────────
$tables  = new TableRepository($projectRoot . '/resources/tables');
$results = [];

foreach ($pairs as $name => ['input' => $inputPath, 'verif' => $verifPath]) {
    fwrite(STDERR, "  $name ... ");
    $tmpOut = sys_get_temp_dir() . '/dpe_diff_' . $name . '.xml';

    try {
        $engine = new DpeEngine(buildPipeline(), $tables);
        $engine->run($inputPath, $tmpOut);

        $expected = filterByTag(readXmlLeaves($verifPath),  $tagSet);
        $actual   = filterByTag(readXmlLeaves($tmpOut),     $tagSet);

        $diffs = diffValues($expected, $actual, $tol);
        fwrite(STDERR, count($diffs) === 0 ? "OK\n" : count($diffs) . " delta(s)\n");
        $results[$name] = ['status' => count($diffs) === 0 ? 'ok' : 'delta', 'diffs' => $diffs, 'error' => null];
    } catch (Throwable $e) {
        fwrite(STDERR, "ERREUR: " . $e->getMessage() . "\n");
        $results[$name] = ['status' => 'error', 'diffs' => [], 'error' => $e->getMessage()];
    } finally {
        @unlink($tmpOut);
    }
}

// ── Rapport ────────────────────────────────────────────────────────────────
if ($jsonMode) {
    echo json_encode($results, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);
    exit(0);
}

$totalDiffs  = 0;
$totalErrors = 0;

foreach ($results as $name => $r) {
    if ($r['status'] === 'ok') continue;

    echo "\n" . str_repeat('═', 70) . "\n";
    echo "  $name\n";
    echo str_repeat('─', 70) . "\n";

    if ($r['status'] === 'error') {
        echo "  ERREUR : " . $r['error'] . "\n";
        $totalErrors++;
        continue;
    }

    // Regrouper les deltas par tag
    $byTag = [];
    foreach ($r['diffs'] as $d) {
        $byTag[$d['tag']][] = $d;
    }
    ksort($byTag);

    foreach ($byTag as $tag => $tagDiffs) {
        echo "\n  [$tag] — " . count($tagDiffs) . " occurrence(s)\n";
        foreach ($tagDiffs as $d) {
            if ($d['delta_abs'] !== null) {
                echo sprintf("    path    : %s\n", $d['path']);
                echo sprintf("    attendu : %s\n", $d['expected']);
                echo sprintf("    obtenu  : %s\n", $d['actual']);
                echo sprintf("    écart   : %.4g abs / %.2f%% rel\n", $d['delta_abs'], $d['delta_rel'] * 100);
            } else {
                echo sprintf("    path    : %s\n", $d['path']);
                echo sprintf("    attendu : %s\n", $d['expected']);
                echo sprintf("    obtenu  : %s\n", $d['actual']);
                echo "    écart   : string mismatch\n";
            }
        }
    }
    $totalDiffs += count($r['diffs']);
}

echo "\n" . str_repeat('═', 70) . "\n";
$ok = count(array_filter($results, fn($r) => $r['status'] === 'ok'));
echo sprintf("  Résumé : %d/%d OK | %d delta(s) | %d erreur(s)\n",
    $ok, count($results), $totalDiffs, $totalErrors);
echo str_repeat('═', 70) . "\n";

exit(($totalDiffs + $totalErrors) > 0 ? 1 : 0);
