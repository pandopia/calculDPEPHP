{
  "name": "pandopia/calcul-dpe-php",
  "description": "Moteur PHP de calcul DPE 3CL-2021",
  "license": "MIT",
  "type": "library",
  "require": {
    "php": "^8.2",
    "ext-dom": "*",
    "ext-libxml": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "CalculDpePHP\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "bin": [
